# Shared GitHub App config for the github-app-identity plugin.
# Copy to ~/.config/gh-app/github-app.env (or set $GITHUB_APP_ENV) and fill in.
# One shared App/config serves all your repos. See setup-runbook.md.

# Numeric App ID (App settings page).
GITHUB_APP_ID=

# Numeric installation ID (the install on your account; covers all its repos).
GITHUB_APP_INSTALLATION_ID=

# Absolute path to the App private key .pem (keep it OUTSIDE any repo).
GITHUB_APP_PRIVATE_KEY_PATH=$HOME/.config/gh-app/app.pem

# The App's slug (from its public URL). Used to build the bot identity.
GITHUB_APP_SLUG=

# Numeric id of the App's bot user: gh api /users/<slug>[bot] --jq .id
GITHUB_APP_BOT_USER_ID=
