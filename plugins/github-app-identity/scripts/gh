#!/usr/bin/env bash
# Directory-aware `gh` shim. Inside a repo that opted into GitHub App identity
# (`git config gh-app.enabled` == true), run gh authenticated as the App, aborting
# rather than falling back to personal auth on token failure. Everywhere else, pass
# through to the real gh unchanged. See the github-app-identity setup runbook.
set -euo pipefail

dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Resolve the real gh: the first gh on PATH that is not this shim (overridable for tests).
resolve_real_gh() {
  if [[ -n "${GH_APP_REAL_GH:-}" ]]; then printf '%s\n' "$GH_APP_REAL_GH"; return 0; fi
  local self="$dir/gh" p cand cdir
  local IFS=:
  for p in $PATH; do
    cand="$p/gh"
    [[ -x "$cand" ]] || continue
    cdir="$(cd "$(dirname "$cand")" 2>/dev/null && pwd)" || continue
    [[ "$cdir/gh" != "$self" ]] && { printf '%s\n' "$cand"; return 0; }
  done
  echo "gh-app shim: no real gh found on PATH" >&2
  return 1
}

real_gh="$(resolve_real_gh)"

# Opted in? Only inside a git repo with the marker set true (or forced for tests).
enabled=false
if [[ "${GH_APP_ENABLED_OVERRIDE:-}" == "true" ]]; then
  enabled=true
elif git rev-parse --is-inside-work-tree >/dev/null 2>&1 \
     && [[ "$(git config --local --get gh-app.enabled 2>/dev/null || true)" == "true" ]]; then
  enabled=true
fi

if [[ "$enabled" != "true" ]]; then
  exec "$real_gh" "$@"
fi

token="$("${GITHUB_APP_TOKEN_CMD:-$dir/github-app-token.sh}")"
if [[ -z "$token" ]]; then
  echo "gh-app shim: refusing to run — empty GitHub App token (would fall back to personal auth)." >&2
  exit 1
fi
[[ -n "${GH_APP_DEBUG:-}" ]] && echo "gh-app shim: running gh as the App" >&2
GH_TOKEN="$token" exec "$real_gh" "$@"
